{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": ["config:recommended"],
	"vulnerabilityAlerts": {
		"labels": ["security"]
	},
	"rebaseWhen": "auto",
	"prCreation": "not-pending",
	"dependencyDashboard": false,
	"rangeStrategy": "bump",
	"minimumReleaseAge": "14 days",
	"rollbackPrs": true,
	"separateMajorMinor": true,
	"timezone": "Europe/Berlin",
	"npmrc": "//npm.pkg.github.com/:_authToken=${GHCR_TOKEN}",
	"hostRules": [
		{
			"hostType": "npm",
			"matchHost": "npm.pkg.github.com",
			"token": "${GHCR_TOKEN}"
		}
	],
	"packageRules": [
		{
			"matchUpdateTypes": ["minor", "patch"],
			"groupName": "Non-breaking updates",
			"matchFileNames": ["package.json", "pnpm", "Cargo.toml", "src-tauri/Cargo.toml"],
			"labels": ["dependencies"],
			"automerge": true
		},
		{
			"matchUpdateTypes": ["major"],
			"matchFileNames": ["package.json", "pnpm", "Cargo.toml", "src-tauri/Cargo.toml"],
			"labels": ["dependencies"],
			"automerge": false
		},
		{
			"matchUpdateTypes": ["patch", "minor"],
			"matchFileNames": [".github/workflows/*.yml"],
			"labels": ["github-actions", "dependencies"],
			"automerge": false
		}
	]
}
