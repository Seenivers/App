{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "default",
	"description": "Capability for the main window",
	"windows": ["main"],
	"permissions": [
		"core:default",
		"opener:default",
		"opener:allow-open-url",
		{
			"identifier": "opener:allow-open-path",
			"allow": [{ "path": "$APPDATA" }, { "path": "$APPDATA/**" }, { "path": "*/**" }]
		},
		"dialog:default",
		"fs:default",
		"fs:allow-exists",
		"fs:allow-create",
		"fs:allow-write-text-file",
		"fs:allow-read-text-file",
		"fs:allow-remove",
		"fs:allow-open",
		"fs:allow-write",
		"fs:allow-stat",
		"fs:allow-copy-file",
		"fs:allow-appdata-read",
		"fs:allow-appdata-write",
		"fs:allow-app-read",
		"fs:allow-app-write",
		"fs:allow-read-dir",
		"fs:allow-localdata-read",
		"fs:allow-localdata-write",
		"fs:allow-resource-read",
		"fs:allow-resource-write",
		"fs:allow-mkdir",
		{
			"identifier": "fs:scope",
			"allow": [{ "path": "$APPDATA" }, { "path": "$APPDATA/**" }, { "path": "*/**" }]
		},
		"sql:default",
		"sql:allow-execute",
		"log:default",
		"process:default"
	]
}
